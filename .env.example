# ============================================
# UniLMS environment template
# Copy to apps/backend/.env and fill in real values.
# Do NOT commit your real .env (it's in .gitignore).
# ============================================

# ─── Database (required) ─────────────────────
# Local dev (host machine):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unilms?schema=public
# Docker compose overrides this with: postgres://postgres:postgres@postgres:5432/unilms

# ─── JWT secrets (required) ──────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# MUST be at least 32 chars. Different secrets for access vs refresh.
JWT_SECRET=replace-with-random-96-char-hex-string-from-crypto-randomBytes
JWT_REFRESH_SECRET=another-different-random-96-char-hex-string-from-crypto-randomBytes
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── LLM / AI (optional — empty = demo mode) ─
# Get yours at https://console.anthropic.com/
# Without this, AI features return demo data marked with _demo:true.
LLM_API_KEY=
# Alternative env name accepted by the code:
# ANTHROPIC_API_KEY=

# ─── SMTP / Email (optional) ─────────────────
# Leave blank to disable email sending (system logs intended messages instead).
# Tip: use https://ethereal.email/ for a free dev mailbox.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@unilms.local

# ─── Telegram bot (optional) ─────────────────
# When set, users can link their Telegram chat from their profile to receive
# notifications. Without this, the Telegram card on /profile shows a "not
# configured" notice and no DMs are attempted (graceful no-op).
#
# How to get a token:
#   1. Open Telegram and start a chat with @BotFather.
#   2. Send /newbot, follow the prompts to set a name + username.
#   3. @BotFather replies with a token like 123456:ABC-xyz... — paste below.
TELEGRAM_BOT_TOKEN=
# Bot username (without @) — used to build deep-link URLs (t.me/<name>?start=...).
TELEGRAM_BOT_USERNAME=uni_lms_bot
# How the backend receives bot updates. `polling` works anywhere (local dev,
# Docker without a public URL) but adds ~30s latency. `webhook` is instant
# but requires a public HTTPS endpoint (Railway/Render/your own domain).
TELEGRAM_MODE=polling
# When TELEGRAM_MODE=webhook this MUST be set — the backend calls setWebhook
# with this URL on startup. Example: https://your-app.up.railway.app
BACKEND_PUBLIC_URL=
# Random 32+ char string. Sent to Telegram as the webhook secret and checked
# against the X-Telegram-Bot-Api-Secret-Token header on every incoming POST.
TELEGRAM_WEBHOOK_SECRET=
# JWT secret used to sign one-time deep-link tokens for the one-tap linking
# flow. Defaults to JWT_SECRET if unset, but using a separate secret is safer.
TELEGRAM_LINK_SECRET=

# ─── File storage (Phase 0) ──────────────────
# `disk` writes uploads under ./uploads (default, fine for local dev).
# `s3` pushes to any S3-compatible bucket — recommended for prod since
# ephemeral container disks lose files on restart.
# Recommended free providers: Cloudflare R2 (10GB free + $0 egress),
# Backblaze B2 (10GB free).
STORAGE_MODE=disk
S3_ENDPOINT=                # e.g. https://<account>.r2.cloudflarestorage.com
S3_BUCKET=                  # bucket name
S3_REGION=auto              # R2 = "auto", AWS = us-east-1 etc.
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=              # Public bucket URL — leave blank for signed reads

# ─── CORS (production only) ──────────────────
# Comma-separated origins. Empty in dev = allow all.
# Example: CORS_ORIGINS=https://unilms.example.com,https://www.unilms.example.com
CORS_ORIGINS=

# ─── Environment ─────────────────────────────
# Affects logging verbosity and CORS strictness
NODE_ENV=development
